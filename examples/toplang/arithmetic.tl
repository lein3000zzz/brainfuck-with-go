// Multiplication: 6 * 7 = 42 is ASCII '*'
var a = 6;
var b = 7;
var product = a * b;
print(product); // prints '*' (ASCII 42 directly)

// Division: 42 / 6 = 7
var quotient = product / a;
var seven = quotient + 48; // '7' = ASCII 55
print(seven);

// Modulo: 10 % 3 = 1
var ten = 10;
var three = 3;
var remainder = ten % three;
var remChar = remainder + 48; // '1' = ASCII 49
print(remChar);

print(10); // newline
